MONGODB_URI=mongodb://localhost:27017/kwh_face_app
JWT_SECRET=change_this_secret_in_production
PORT=4000

# Set to 1 to include error detail in login/API responses when NODE_ENV=production
AUTH_LOGIN_DEBUG=

# Allow browser clients on https://<your-server>:1000 (set on the remote host behind nginx TLS)
CORS_ALLOW_HTTPS=true

# CompreFace (optional - for CCTVs face detection)
COMPREFACE_URL=http://localhost:8000
COMPREFACE_RECOGNITION_API_KEY=
